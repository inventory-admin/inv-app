{
  "name": "inv-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --verbose",
    "test:watch": "jest --watch --verbose",
    "test:coverage": "jest --coverage --verbose",
    "seed": "tsx prisma/seed.ts",
    "db:up": "docker run -d --name inv-postgres -e POSTGRES_DB=inventory -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -p 5432:5432 -v inv_postgres_data:/var/lib/postgresql/data postgres:15 || docker start inv-postgres",
    "db:down": "docker stop inv-postgres || true",
    "db:setup": "prisma migrate dev && npm run seed",
    "db:reset": "prisma migrate reset --force && npm run seed",
    "dev:setup": "npm run db:up && sleep 5 && npm run db:setup"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "next": "14.2.35",
    "prisma": "^6.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
